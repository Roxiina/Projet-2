# Database Configuration
# ⚠️ Pour le développement local, vous pouvez utiliser ces valeurs par défaut
POSTGRES_USER=projet2_user
POSTGRES_PASSWORD=projet2_password
POSTGRES_DB=projet2_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# API Configuration
API_URL=http://api:8000

# Application Settings
ENVIRONMENT=development

# DockerHub Configuration (pour docker-compose.prod.yml)
# ⚠️ Remplacez par votre nom d'utilisateur DockerHub pour le déploiement
DOCKERHUB_USERNAME=your_dockerhub_username
